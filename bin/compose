#!/usr/bin/env bash

set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
project_dir="$(cd -- "$script_dir/.." && pwd)"
local_override="$project_dir/.brezel-state/compose.links.yaml"
runtime_override="$project_dir/.brezel-state/compose.runtime.yaml"
project_base="$(basename "$project_dir")"
project_base="$(printf '%s' "$project_base" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-+/-/g')"
project_hash="$(printf '%s' "$project_dir" | cksum)"
project_hash="${project_hash%% *}"
project_name="brezel-${project_base:-project}-${project_hash}"

if ! command -v docker >/dev/null 2>&1; then
  printf 'docker is required for bin/compose but was not found in PATH.\n' >&2
  exit 1
fi

compose_args=(
  --project-name "$project_name"
  --project-directory "$project_dir"
  -f "$project_dir/docker-compose.yaml"
)

if [ -f "$local_override" ]; then
  compose_args+=( -f "$local_override" )
fi

if [ -f "$runtime_override" ]; then
  compose_args+=( -f "$runtime_override" )
fi

exec docker compose \
  "${compose_args[@]}" \
  "$@"
