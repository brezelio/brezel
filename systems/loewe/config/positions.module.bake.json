[
  {
    "resource_module": "positions",
    "resource": {
      "identifier": "positions",
      "icon": "mdi:format-list-numbered",
      "title": "number.\" — \".provider.\" / \".tariff",
      "layouts": {
        "detail": "config/positions.layout.detail",
        "index": "config/positions.layout.index"
      },
      "buttons": {
        "CreateContractFromPosition": {
          "icon": "mdi:file-sign",
          "show_in": ["module.show"],
          "options": {
            "recipes": {
              "hidden_from_frontend": "!this.offer || this.contract || this.status != 'pending'"
            }
          }
        }
      },
      "fields": [
        {
          "identifier": "number",
          "type": "incrementing",
          "options": {
            "decimal_digits": 0
          }
        },
        {
          "identifier": "offer",
          "type": "select",
          "options": {
            "references": "offers",
            "pre_filters": [
              {
                "column": "customer.id",
                "operator": "=",
                "field": "customer.id"
              }
            ]
          }
        },
        {
          "identifier": "contract",
          "type": "select",
          "options": {
            "references": "contracts",
            "pre_filters": [
              {
                "column": "customer.id",
                "operator": "=",
                "field": "customer.id"
              }
            ]
          }
        },
        {
          "identifier": "customer",
          "type": "select",
          "options": {
            "references": "customers",
            "rules": "required"
          }
        },
        {
          "identifier": "location",
          "type": "select",
          "options": {
            "references": "locations",
            "rules": "required",
            "pre_filters": [
              {
                "column": "customer.id",
                "operator": "=",
                "field": "customer.id"
              }
            ]
          }
        },
        {
          "identifier": "partner",
          "type": "select",
          "options": {
            "references": "users"
          }
        },
        {
          "identifier": "meter_type",
          "type": "choice",
          "options": {
            "values": ["slp", "rlm"],
            "default": "slp"
          }
        },
        {
          "identifier": "tariff_catalog",
          "type": "select",
          "options": {
            "references": "tariffs",
            "add_options": true,
            "pre_filters": [
              {
                "column": "meter_type",
                "operator": "=",
                "field": "meter_type"
              },
              {
                "column": "active",
                "operator": "=",
                "value": true
              }
            ]
          }
        },
        {
          "identifier": "provider",
          "type": "text"
        },
        {
          "identifier": "tariff",
          "type": "text"
        },
        {
          "identifier": "duration",
          "type": "number"
        },
        {
          "identifier": "usage",
          "type": "number"
        },
        {
          "identifier": "start_date",
          "type": "date"
        },
        {
          "identifier": "prov_partner",
          "type": "number"
        },
        {
          "identifier": "prov_loewe",
          "type": "number"
        },
        {
          "identifier": "grid_usage_fee",
          "type": "number"
        },
        {
          "identifier": "grid_fixed_fee",
          "type": "number"
        },
        {
          "identifier": "concession_fee",
          "type": "number"
        },
        {
          "identifier": "metering_fee",
          "type": "number"
        },
        {
          "identifier": "grid_capacity_fee",
          "type": "number",
          "options": {
            "recipes": {
              "hidden_from_frontend": "meter_type != 'rlm'",
              "frontend_disabled": "meter_type != 'rlm'"
            }
          }
        },
        {
          "identifier": "grid_charges_total",
          "type": "number",
          "options": {
            "readonly": true,
            "frontend_disabled": true
          },
          "recipe": "(grid_usage_fee ?? 0) + (grid_fixed_fee ?? 0) + (concession_fee ?? 0) + (metering_fee ?? 0) + (meter_type == 'rlm' ? (grid_capacity_fee ?? 0) : 0)"
        },
        {
          "identifier": "kwkg_levy",
          "type": "number"
        },
        {
          "identifier": "special_grid_levy",
          "type": "number"
        },
        {
          "identifier": "offshore_levy",
          "type": "number"
        },
        {
          "identifier": "electricity_tax",
          "type": "number"
        },
        {
          "identifier": "state_levies_total",
          "type": "number",
          "options": {
            "readonly": true,
            "frontend_disabled": true
          },
          "recipe": "(kwkg_levy ?? 0) + (special_grid_levy ?? 0) + (offshore_levy ?? 0) + (electricity_tax ?? 0)"
        },
        {
          "identifier": "site_fixed_fee",
          "type": "number"
        },
        {
          "identifier": "energy_price",
          "type": "number"
        },
        {
          "identifier": "usage_price",
          "type": "number",
          "options": {
            "readonly": true,
            "frontend_disabled": true
          },
          "recipe": "(grid_usage_fee ?? 0) + (concession_fee ?? 0) + (kwkg_levy ?? 0) + (special_grid_levy ?? 0) + (offshore_levy ?? 0) + (electricity_tax ?? 0) + (energy_price ?? 0)"
        },
        {
          "identifier": "supplier_energy_total",
          "type": "number",
          "options": {
            "readonly": true,
            "frontend_disabled": true
          },
          "recipe": "(site_fixed_fee ?? 0) + ((usage ?? 0) * (usage_price ?? 0) / 100)"
        },
        {
          "identifier": "total_cost",
          "type": "number",
          "options": {
            "readonly": true,
            "frontend_disabled": true
          },
          "recipe": "(grid_charges_total ?? 0) + (state_levies_total ?? 0) + (supplier_energy_total ?? 0)"
        },
        {
          "identifier": "total_savings",
          "type": "number",
          "options": {
            "readonly": true,
            "frontend_disabled": true
          }
        },
        {
          "identifier": "potential_savings",
          "type": "number",
          "options": {
            "readonly": true,
            "frontend_disabled": true
          }
        },
        {
          "identifier": "status",
          "type": "choice",
          "options": {
            "values": ["pending", "signed", "active", "cancelled"],
            "default": "pending"
          }
        }
      ]
    }
  }
]
