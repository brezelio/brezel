        },
        {
          "identifier": "phone",
          "type": "tel"
        },
        {
          "identifier": "mobile",
          "type": "tel"
        },
        {
          "identifier": "iban",
          "type": "text"
        },
        {
          "identifier": "bic",
          "type": "text"
        },
        {
          "identifier": "default_address",
          "type": "select",
          "options": {
            "references": "addresses",
            "add_options": true,
            "pre_filters": [
              {
                "column": "customer.id",
                "operator": "=",
                "field": "id"
              }
            ]
          }
        },
        {
          "identifier": "default_billing_address",
          "type": "select",
          "options": {
            "references": "addresses",
            "add_options": true,
            "pre_filters": [
              {
                "column": "customer.id",
                "operator": "=",
                "field": "id"
              }
            ]
          }
        },
        {
          "identifier": "default_shipping_address",
          "type": "select",
          "options": {
            "references": "addresses",
            "add_options": true,
            "pre_filters": [
              {
                "column": "customer.id",
                "operator": "=",
                "field": "id"
              }
            ]
          }
        },
        {
          "identifier": "default_bank",
          "type": "text"
        },
        {
          "identifier": "default_iban",
          "type": "text"
        },
        {
          "identifier": "default_bic",
          "type": "text"
        },
        {
          "identifier": "sf_account_id",
          "type": "text"
        },
        {
          "identifier": "sf_contact_id",
          "type": "text"
        },
        {
