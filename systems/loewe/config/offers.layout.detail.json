{
  "tabs": [
    {
      "identifier": "general",
      "icon": "mdi:file-document-outline",
      "rows": [
        {
          "cols": [
            {
              "span": 24,
              "components": [
                {
                  "type": "headline",
                  "options": {
                    "identifier": "basic"
                  }
                },
                {
                  "type": "field_group",
                  "options": {
                    "vertical_labels": true,
                    "fields": [
                      "number",
                      "customer",
                      "partner",
                      ["status", "type"],
                      ["created_at", "valid_till"]
                    ]
                  }
                },
                {
                  "type": "buttons",
                  "options": {
                    "buttons": [
                      {
                        "identifier": "CalculateOffer",
                        "icon": "mdi:calculator-variant",
                        "style": "primary",
                        "options": {
                          "recipes": {
                            "hidden_from_frontend": "status != 'draft'"
                          }
                        }
                      },
                      {
                        "identifier": "MarkOfferSent",
                        "icon": "mdi:send",
                        "options": {
                          "recipes": {
                            "hidden_from_frontend": "status != 'calculated'"
                          }
                        }
                      },
                      {
                        "identifier": "ExportOfferPdf",
                        "icon": "mdi:file-pdf-box",
                        "options": {
                          "recipes": {
                            "hidden_from_frontend": "status == 'draft' || status == 'rejected'"
                          }
                        }
                      }
                    ]
                  }
                }
              ]
            }
          ]
        },
        {
          "cols": [
            {
              "span": 24,
              "options": {
                "recipes": {
                  "hidden_from_frontend": "!id"
                }
              },
              "components": [
                {
                  "type": "headline",
                  "options": {
                    "identifier": "positions"
                  }
                },
                {
                  "type": "resource_table",
                  "options": {
                    "module": "positions",
                    "create_in_modal": true,
                    "edit_in_modal": true,
                    "show_in_modal": true,
                    "pre_filters": [
                      {
                        "column": "offer.id",
                        "operator": "=",
                        "recipe": "this.id"
                      }
                    ],
                    "recipes": {
                      "fill": "{'offer': this, 'customer': this.customer, 'partner': this.partner}"
                    },
                    "buttons": [
                      {
                        "identifier": "CreateContractFromPosition",
                        "icon": "mdi:file-sign",
                        "help": "Create contract",
                        "event": "CreateContractFromPosition",
                        "options": {
                          "recipes": {
                            "hidden_from_frontend": "!$context.record.offer || $context.record.contract || $context.record.status != 'pending'"
                          }
                        }
                      }
                    ]
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
