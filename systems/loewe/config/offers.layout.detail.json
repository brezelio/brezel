{
  "tabs": [
    {
      "identifier": "general",
      "icon": "mdi:file-document-outline",
      "rows": [
        {
          "cols": [
            {
              "span": 24,
              "components": [
                {
                  "type": "headline",
                  "options": {
                    "identifier": "basic"
                  }
                },
                {
                  "type": "field_group",
                  "options": {
                    "vertical_labels": true,
                    "fields": [
                      "number",
                      "customer",
                      "user",
                      ["status", "type"],
                      ["created_at", "valid_till"],
                      "inquiry_notes"
                    ]
                  }
                },
                {
                  "type": "buttons",
                  "options": {
                    "buttons": [
                      {
                        "identifier": "CalculateOffer",
                        "icon": "mdi:calculator-variant",
                        "style": "primary",
                        "options": {
                          "recipes": {
                            "hidden_from_frontend": "status != 'draft' || type == 'individual'"
                          }
                        }
                      },
                      {
                        "identifier": "MarkOfferSent",
                        "icon": "mdi:send",
                        "options": {
                          "recipes": {
                            "hidden_from_frontend": "status != 'calculated'"
                          }
                        }
                      },
                      {
                        "identifier": "ExportOfferPdf",
                        "icon": "mdi:file-pdf-box",
                        "options": {
                          "recipes": {
                            "hidden_from_frontend": "status == 'draft' || status == 'rejected' || type == 'individual'"
                          }
                        }
                      },
                      {
                        "identifier": "edit_in_wizard",
                        "icon": "mdi:pencil-outline",
                        "style": "default",
                        "event": {
                          "action": "open",
                          "type": "entity",
                          "module": "quotation_wizard",
                          "moduleAction": "module",
                          "options": {
                            "query": {
                              "offer": "this.id"
                            }
                          }
                        },
                        "options": {
                          "recipes": {
                            "hidden_from_frontend": "status != 'draft' || type == 'individual'"
                          }
                        }
                      },
                      {
                        "identifier": "DuplicateOffer",
                        "icon": "mdi:content-copy",
                        "style": "default",
                        "options": {
                          "recipes": {
                            "hidden_from_frontend": "!id"
                          }
                        }
                      }
                    ]
                  }
                }
              ]
            }
          ]
        },
        {
          "cols": [
            {
              "span": 24,
              "components": [
                {
                  "type": "headline",
                  "options": {
                    "identifier": "documents"
                  }
                },
                {
                  "type": "field_group",
                  "options": {
                    "vertical_labels": true,
                    "fields": [
                      "attachments"
                    ]
                  }
                }
              ]
            }
          ]
        },
        {
          "cols": [
            {
              "span": 24,
              "options": {
                "recipes": {
                  "hidden_from_frontend": "!id || type == 'individual'"
                }
              },
              "components": [
                {
                  "type": "headline",
                  "options": {
                    "identifier": "positions"
                  }
                },
                {
                  "type": "resource_table",
                  "options": {
                    "module": "positions",
                    "create_in_modal": true,
                    "edit_in_modal": true,
                    "show_in_modal": true,
                    "columns": [
                      "number",
                      "location",
                      "provider",
                      "tariff",
                      "usage",
                      "total_cost",
                      "total_savings",
                      "status"
                    ],
                    "pre_filters": [
                      {
                        "column": "offer.id",
                        "operator": "=",
                        "recipe": "this.id"
                      }
                    ],
                    "recipes": {
                      "fill": "{'offer': this, 'customer': this.customer, 'partner': this.user}"
                    },
                    "buttons": [
                      {
                        "identifier": "CreateContractFromPosition",
                        "icon": "mdi:file-sign",
                        "help": "Create contract",
                        "event": "CreateContractFromPosition",
                        "options": {
                          "recipes": {
                            "hidden_from_frontend": "!$context.record.offer || $context.record.contract || $context.record.status != 'pending'"
                          }
                        }
                      }
                    ]
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
